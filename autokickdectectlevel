local ArgAutostart, ArgAutokick, ArgLevelOut = ...

local Autostart = ArgAutostart or getgenv().Autostart or "true"
local Autokick  = ArgAutokick  or getgenv().Autokick  or "true"
local LevelOut  = ArgLevelOut  or getgenv().LevelOut  or "1350"

local CHECK_INTERVAL = 0.20
local UI_INTERVAL = 0.25
local PATH_REFRESH_INTERVAL = 2
local MAX_LEVEL = 2800

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")
local LP = Players.LocalPlayer

local AUTOSTART = tostring(Autostart):lower()
local AUTOKICK = tostring(Autokick):lower()
local TARGET_LEVEL = tonumber(tostring(LevelOut):match("%d+")) or 0

local DATA = {
    level = nil,
}

local PATH = {
    dataLevel = nil,
    main = nil,
    levelGui = nil,
}

local STATE = {
    running = false,
    destroyed = false,
    kicked = false,
    source = "Stopped",
    alert = "Stopped",
    safe = true,
}

local function safe(fn)
    local ok, res = pcall(fn)
    if ok then return res end
    return nil
end

local function readText(obj)
    if not obj then return nil end
    local v = safe(function() return obj.Text end)
    if v == nil then return nil end
    return tostring(v)
end

local function readValue(obj)
    if not obj then return nil end
    return safe(function() return obj.Value end)
end

local function refreshPaths()
    local pg = LP:FindFirstChildOfClass("PlayerGui")
    local data = LP:FindFirstChild("Data")

    PATH.dataLevel = data and data:FindFirstChild("Level") or nil
    PATH.main = pg and pg:FindFirstChild("Main") or nil
    PATH.levelGui = PATH.main and PATH.main:FindFirstChild("Level") or nil
end

local function readLevel()
    local level = tonumber(readValue(PATH.dataLevel))
    if not level then
        local lvText = readText(PATH.levelGui)
        level = lvText and tonumber(lvText:match("Lv%.?%s*(%d+)")) or nil
    end

    if level and level >= 1 and level <= MAX_LEVEL then
        DATA.level = level
    end

    return DATA.level
end

local function kickNow()
    if STATE.kicked then return end
    STATE.kicked = true
    task.wait(0.12)
    pcall(function()
        LP:Kick("[LevelOut] Level da toi moc " .. tostring(TARGET_LEVEL))
    end)
    task.wait(1)
    pcall(function()
        game:Shutdown()
    end)
end

pcall(function()
