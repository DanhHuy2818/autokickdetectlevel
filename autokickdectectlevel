local resizing = false
local resizeStartMouse = nil
local resizeStartScale = nil
local resizeInput = nil

local function beginResize(pos, input)
    resizing = true
    resizeStartMouse = pos
    resizeStartScale = scale.Scale
    resizeInput = input
end

resize.MouseButton1Down:Connect(function()
    beginResize(UIS:GetMouseLocation(), nil)
end)

resize.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.Touch then
        beginResize(Vector2.new(input.Position.X, input.Position.Y), input)
    end
end)

UIS.InputChanged:Connect(function(input)
    if not resizing then return end
    if input.UserInputType == Enum.UserInputType.MouseMovement or input == resizeInput then
        local pos = input.UserInputType == Enum.UserInputType.MouseMovement
            and UIS:GetMouseLocation()
            or Vector2.new(input.Position.X, input.Position.Y)
        local dx = (pos.X - resizeStartMouse.X) / 220
        local dy = (pos.Y - resizeStartMouse.Y) / 240
        local delta = math.abs(dx) > math.abs(dy) and dx or dy
        scale.Scale = math.clamp(resizeStartScale + delta, 0.55, 1.35)
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input == resizeInput then
        resizing = false
        resizeInput = nil
    end
end)

local lastPathRefresh = 0
local loopConn = nil

local function updateLogic()
    local now = tick()
    if now - lastPathRefresh >= PATH_REFRESH_INTERVAL then
        lastPathRefresh = now
        refreshPaths()
    end

    local ok, err = pcall(readLevel)
    if not ok then
        STATE.source = "Read error"
        STATE.alert = tostring(err):sub(1, 80)
        STATE.safe = true
        return
    end

    local lv = DATA.level
    if not lv then
        STATE.source = "No level"
        STATE.alert = "Dang tim level"
        STATE.safe = true
        return
    end

    if TARGET_LEVEL <= 0 then
        STATE.source = "No moc"
        STATE.alert = "Sua LevelOut truoc"
        STATE.safe = true
        return
    end

    if lv >= TARGET_LEVEL then
        STATE.source = "STOP"
        STATE.alert = "Level >= " .. tostring(TARGET_LEVEL)
        STATE.safe = false
        if AUTOKICK == "true" and STATE.running then
            STATE.running = false
            task.spawn(kickNow)
        end
    else
        STATE.source = "OK"
        STATE.alert = "Dang cho moc"
        STATE.safe = true
    end
end

local function updateUi()
    vSrc.Text = STATE.running and STATE.source or "Stopped"
    vSrc.TextColor3 = STATE.safe and Color3.fromRGB(80, 255, 120) or Color3.fromRGB(255, 90, 80)
    vLv.Text = DATA.level and tostring(DATA.level) or "--"
    vTarget.Text = TARGET_LEVEL > 0 and tostring(TARGET_LEVEL) or "--"
    vKick.Text = AUTOKICK == "true" and "ON" or "OFF"
    vKick.TextColor3 = AUTOKICK == "true" and Color3.fromRGB(255, 80, 80) or Color3.fromRGB(255, 210, 80)

    alertText.Text = STATE.running and STATE.alert or "Stopped"
    if STATE.running and not STATE.safe then
        alertText.TextColor3 = Color3.fromRGB(255, 120, 80)
        alertBox.BackgroundColor3 = Color3.fromRGB(55, 10, 10)
    elseif STATE.running then
        alertText.TextColor3 = Color3.fromRGB(80, 220, 120)
        alertBox.BackgroundColor3 = Color3.fromRGB(10, 22, 14)
    else
        alertText.TextColor3 = Color3.fromRGB(130, 130, 150)
        alertBox.BackgroundColor3 = Color3.fromRGB(14, 14, 26)
    end
end

local function startLoop()
    if loopConn then loopConn:Disconnect() end
    local lastCheck = 0
    local lastUi = 0
    loopConn = RunService.Heartbeat:Connect(function()
        if STATE.destroyed then return end
        local now = tick()
        if STATE.running and now - lastCheck >= CHECK_INTERVAL then
            lastCheck = now
            updateLogic()
        end
        if now - lastUi >= UI_INTERVAL then
            lastUi = now
            updateUi()
        end
    end)
end

toggleBtn.MouseButton1Click:Connect(function()
    STATE.running = not STATE.running
    if STATE.running then
        toggleBtn.Text = "Stop"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(150, 20, 20)
        refreshPaths()
        updateLogic()
        startLoop()
    else
        toggleBtn.Text = "Start"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(0, 140, 60)
        updateUi()
    end
end)

closeBtn.MouseButton1Click:Connect(function()
    STATE.destroyed = true
    STATE.running = false
    if loopConn then loopConn:Disconnect() end
    gui:Destroy()
end)

refreshPaths()
pcall(readLevel)
updateLogic()
updateUi()
startLoop()

if AUTOSTART == "true" then
    task.wait(1)
    STATE.running = true
    toggleBtn.Text = "Stop"
    toggleBtn.BackgroundColor3 = Color3.fromRGB(150, 20, 20)
end

